{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Alectra",
  "version": "1.0.0",
  "identifier": "co.za.alectra.app",
  "build": {
    "frontendDist": "https://alectra.co.za",
    "devUrl": "https://alectra.co.za"
  },
  "app": {
    "windows": [
      {
        "title": "Alectra Solutions",
        "url": "https://alectra.co.za"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    }
  }
}
